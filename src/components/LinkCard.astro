---
import ArrowRight from '@/components/Icon/ArrowRight.astro';
type Props = {
  label: string;
  href: string;
};
const { label, href } = Astro.props;
const isExternal = href.startsWith('http');
const rel = isExternal ? 'noopener noreferrer' : undefined;
const target = isExternal ? '_blank' : undefined;
---

<a
  class="border border-blue-1000 rounded p-4 flex items-center justify-between text-blue-1000
  hover:bg-blue-50 hover:underline
  focus-visible:rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-focus-yellow
  dark:border-cyan-200 dark:text-cyan-200 dark:hover:bg-cyan-1000"
  href={href}
  rel={rel}
  target={target}>{label}<ArrowRight /></a
>
